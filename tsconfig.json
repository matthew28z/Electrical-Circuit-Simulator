{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "target": "esnext",
        "module": "esnext",
        "strict": true,
        "types": ["vitest/browser"],
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "noEmit": true
    },
    "include": ["**/*.ts", "**/*.js"]
}